{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Church App Foundation",
  "version": "0.1.0",
  "identifier": "org.churchapp.foundation",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Church App Foundation",
        "width": 960,
        "height": 680,
        "minWidth": 360,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": { "active": false, "icon": [] }
}
